#!/usr/bin/env sh

# 1) Format code (no format:check)
echo "🔧 Formatting code before commit..."
pnpm format
if [ $? -ne 0 ]; then
  echo "❌ Formatting failed!"
  exit 1
fi

# Stage the formatted files
git add -u

echo "✅ Code formatted and staged"

echo "--------------------------------"

# 2) Lint
echo "🔎 Linting code..."
pnpm lint
if [ $? -ne 0 ]; then
  echo "❌ Linting failed!"
  exit 1
fi

echo "✅ Linting passed"

echo "--------------------------------"

# 3) Build
echo "🏗️  Building project..."
pnpm build
if [ $? -ne 0 ]; then
  echo "❌ Build failed!"
  exit 1
fi

echo "✅ Build passed"

echo "--------------------------------"

# 4) Branch check (block master)
current_branch=$(git branch --show-current)

if [ "$current_branch" = "master" || "$current_branch" = "main" ]; then
  echo "❌ Committing directly to 'master' or 'main' branch is not allowed!"
  echo "Please create a pull request instead."
  exit 1
fi

echo "✅ All pre-commit checks passed!"

exit 0
